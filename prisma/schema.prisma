generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum QuestCategory {
  DRINKS
  PHOTO
  PARTY
  BONUS
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FeedType {
  QUEST_SUBMITTED
  QUEST_APPROVED
  BADGE_EARNED
  STREAK
}

model User {
  id          String       @id @default(cuid())
  name        String
  nickname    String?
  photoUrl    String?
  points      Int          @default(0)
  drinks      Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  submissions Submission[]
  badges      UserBadge[]
  feedItems   FeedItem[]
}

model Quest {
  id          String       @id @default(cuid())
  title       String       @unique
  description String
  category    QuestCategory
  points      Int
  drinks      Int          @default(0)
  icon        String
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  submissions Submission[]
}

model Submission {
  id         String           @id @default(cuid())
  userId     String
  questId    String
  photoUrl   String?
  caption    String?
  status     SubmissionStatus @default(PENDING)
  points     Int
  drinks     Int              @default(0)
  createdAt  DateTime         @default(now())
  reviewedAt DateTime?
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest      Quest            @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId])
  @@index([questId])
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  icon        String
  createdAt   DateTime    @default(now())
  users       UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

model FeedItem {
  id        String   @id @default(cuid())
  userId    String?
  type      FeedType
  text      String
  points    Int      @default(0)
  icon      String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}
